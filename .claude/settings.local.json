{
  "permissions": {
    "allow": [
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git remote:*)",
      "Bash(git push:*)",
      "Bash(git rm:*)",
      "Skill(update-config)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /c/Users/dov/baderech && git add -A && git diff --cached --quiet || (git commit -m \"auto: update\" && git push origin master) 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "מעלה ל-GitHub..."
          }
        ]
      }
    ]
  }
}
